{
  "name": "inimbleapp",
  "version": "4.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration=production",
    "build:stage": "ng build --configuration=stage",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write .",
    "refactor:check-legacy": "powershell -ExecutionPolicy Bypass -File ./tools/refactor/check-legacy-imports.ps1",
    "prepare": "husky",
    "analyze:baseline:prod": "mkdir -p bundle-analysis/baseline && ng build --configuration=analysis-prod --stats-json && source-map-explorer 'dist/browser/*.js' --html bundle-analysis/baseline/baseline-report-prod.html --no-border-checks && cp dist/stats.json bundle-analysis/baseline/baseline-stats-prod.json",
    "analyze:baseline:dev": "mkdir -p bundle-analysis/baseline && ng build --configuration=development --source-map --stats-json && source-map-explorer 'dist/browser/*.js' --html bundle-analysis/baseline/baseline-report-dev.html --no-border-checks && cp dist/stats.json bundle-analysis/baseline/baseline-stats-dev.json",
    "analyze:wb:prod": "webpack-bundle-analyzer bundle-analysis/baseline/baseline-stats-prod.json --mode static --report bundle-analysis/baseline/baseline-report-wb-prod.html --no-open",
    "analyze:wb:dev": "webpack-bundle-analyzer bundle-analysis/baseline/baseline-stats-dev.json --mode static --report bundle-analysis/baseline/baseline-report-wb-dev.html --no-open"
  },
  "private": true,
  "dependencies": {
    "@amcharts/amcharts5": "^5.10.10",
    "@amcharts/amcharts5-geodata": "^5.1.4",
    "@angular-slider/ngx-slider": "^20.0.0",
    "@angular/animations": "^19.0.4",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.0.4",
    "@angular/compiler": "^19.0.4",
    "@angular/core": "^19.0.4",
    "@angular/fire": "^19.1.0",
    "@angular/forms": "^19.0.4",
    "@angular/material": "19.0.3",
    "@angular/platform-browser": "^19.0.4",
    "@angular/platform-browser-dynamic": "^19.0.4",
    "@angular/router": "^19.0.4",
    "@auth0/angular-jwt": "^5.1.2",
    "@capacitor/android": "^7.4.4",
    "@capacitor/angular": "^2.0.3",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/core": "^7.4.4",
    "@capacitor/filesystem": "^7.1.4",
    "@capacitor/ios": "^7.4.4",
    "@ctrl/ngx-emoji-mart": "^9.3.0",
    "@emoji-mart/data": "^1.2.1",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@kolkov/angular-editor": "^2.1.0",
    "@ng-matero/extensions": "^17.0.0",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/signals": "^17.2.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "@stripe/stripe-js": "^7.5.0",
    "angular-calendar": "^0.29.0",
    "angular-feather": "^6.5.1",
    "angular-tabler-icons": "^2.7.0",
    "apexcharts": "3.43.0",
    "capacitor-native-settings": "^7.0.2",
    "capacitor-voice-recorder": "^7.0.6",
    "chance": "^1.1.12",
    "chart.js": "^4.4.1",
    "cordova-open-native-settings": "^1.5.5",
    "cordova-plugin-android-permissions": "^1.1.5",
    "d3": "^7.9.0",
    "d3-org-chart": "^3.1.1",
    "date-fns": "^2.29.3",
    "ddp-client": "^0.1.2",
    "file-saver": "^2.0.5",
    "firebase": "^11.9.1",
    "highlight.js": "^11.11.0",
    "js-cookie": "^3.0.5",
    "jspdf": "^2.5.1",
    "leaflet": "^1.9.4",
    "luxon": "^3.7.2",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.46",
    "ng-apexcharts": "^1.11.0",
    "ng2-pdf-viewer": "^10.4.0",
    "ng2-search-filter": "^0.5.1",
    "ngx-dropzone": "^3.1.0",
    "ngx-highlightjs": "^12.0.0",
    "ngx-material-timepicker": "^13.1.1",
    "ngx-pagination": "^6.0.1",
    "ngx-permissions": "^13.0.1",
    "ngx-scrollbar": "^11.0.0",
    "ngx-socket-io": "^4.6.1",
    "ngx-toastr": "^19.0.0",
    "ngx-ui-tour-core": "^14.0.0",
    "ngx-ui-tour-md-menu": "^14.0.0",
    "rxjs": "~7.5.0",
    "sass": "^1.57.1",
    "socket.io-client": "^4.6.2",
    "sweetalert2": "^11.10.5",
    "swiper": "^11.2.5",
    "tslib": "^2.3.0",
    "twemoji": "^14.0.2",
    "uuid": "^11.1.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.5",
    "@angular/cli": "~19.0.5",
    "@angular/compiler-cli": "^19.0.4",
    "@ngrx/schematics": "^21.1.0",
    "@types/chance": "^1.1.6",
    "@types/date-fns": "^2.6.0",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~4.3.0",
    "@types/js-cookie": "^3.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/luxon": "^3.7.1",
    "@types/moment": "^2.13.0",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.6.3",
    "typescript-eslint": "8.46.4",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{scss,json}": [
      "prettier --write"
    ]
  }
}
